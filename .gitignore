# Artefactos reproducibles (se regeneran desde las fotos; sus hashes quedan en audit.log)
projects/*/work/

# Fotos de entrada: pesadas para git. Sus SHA-256 quedan en work/00_intake y audit.log.
# Para versionarlas usa git-lfs y elimina estas dos líneas.
projects/*/input/photos/*
!projects/*/input/photos/.gitkeep

# Material web descargado (reproducible: URLs en audit.log y refs/_fuentes.txt)
projects/*/input/video/
projects/*/input/refs/*
!projects/*/input/refs/_fuentes.txt

# Modelos pesados: se versionan los de 70_web (entregable). Si superan ~100 MB usa git-lfs.
projects/*/out/*.ply
projects/*/out/*.mvs

# Salidas de la biblioteca de componentes (se regeneran del catalogo)
componentes/out/

__pycache__/
*.pyc
.venv/

# STL teselados del STEP (derivados grandes, regenerables con tools/step_to_stl.py)
cad/ensambles/*.stl
